# =============================================================================
# AETHEL .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.env
.venv
venv/
env/
pip-wheel-metadata/

# ---------------------------------------------------------------------------
# Outputs — generated at runtime, not version-controlled
# ---------------------------------------------------------------------------
outputs/
results/
experiments/
!experiments/**/.gitkeep

# ---------------------------------------------------------------------------
# Data — raw CSVs are generated by the pipeline, not stored in git
# Keep .gitkeep files to preserve directory structure
# ---------------------------------------------------------------------------
data/raw/*.csv
data/processed/*.csv
data/synthetic/*.csv
data/nhanes/*.csv
data/framingham/*.csv
!data/**/.gitkeep

# ---------------------------------------------------------------------------
# R
# ---------------------------------------------------------------------------
.Rhistory
.RData
.Rproj.user/
*.Rproj

# ---------------------------------------------------------------------------
# Quarto / Jupyter
# ---------------------------------------------------------------------------
/.quarto/
_site/
_book/
*.html
*.nb.html
.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.DS_Store
Thumbs.db
*.swp
*.swo

# ---------------------------------------------------------------------------
# Logs (if accidentally placed outside outputs/)
# ---------------------------------------------------------------------------
*.log
